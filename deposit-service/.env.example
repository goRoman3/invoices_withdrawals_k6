# deposit-service/.env.example — шаблон окружения для TRON deposit-сервиса.
# Скопируй в .env.local и подставь реальные значения:
#   cp .env.example .env.local
# .env.local в .gitignore и НЕ коммитится.

PORT=8099

# TRON node (Shasta testnet по умолчанию)
FULL_HOST=https://api.shasta.trongrid.io

# СЕКРЕТЫ — держать только в .env.local, никогда не коммитить
TRON_PRIVATE_KEY=__SET_ME__
TRON_PRO_API_KEY=__SET_ME__

# TRC20-контракт токена
TOKEN_CONTRACT=__SET_ME__
TOKEN_DECIMALS=6

# Не отправлять реальные транзакции (1/true/yes)
# DRY_RUN=true
