# k6/.env.example — шаблон окружения для нагрузочных сценариев.

# ---------- Прогон ----------
K6_SCRIPT=main.invoices.arrival.js
VUS=1
ITERATIONS=1
ITERATION_DELAY=1
MAX_DURATION=10m

# ---------- Ретраи ----------
HTTP_RETRIES=2
INVOICE_RETRIES=1
LIST_RETRIES=1

# ---------- API ----------
BASE_URL=https://__API_HOST__

# ---------- Keycloak / OAuth ----------
KEYCLOAK_TOKEN_URL=https://__KEYCLOAK_HOST__/realms/__REALM__/protocol/openid-connect/token
CLIENT_ID=__SET_ME__
CLIENT_SECRET=__SET_ME__
USERNAME=__SET_ME__
PASSWORD=__SET_ME__
SCOPE='openid email profile roles organization:*'
# ACCESS_TOKEN_MANUAL=

# ---------- OTP / TOTP ----------
OTP_SECRET=__SET_ME_BASE32__
OTP_FIELD=totp
OTP_MODE=body
OTP_HEADER_NAME=X-OTP
OTP_PROVIDER_URL=
OTP_SERVER_PORT=
# OTP_MANUAL=
# NODE_TOTP_JS=../tools/totp-node/totp.js
# NODE_OTP_SERVER_JS=../tools/totp-node/server.js

# ---------- Subproject ----------
SUBPROJECT_NAME=__SET_ME__
SUBPROJECT_ID=__SET_ME_UUID__
SUBPROJECT_HEADER=x-subproject-id

# ---------- Invoice defaults ----------
ASSET_UUID=__SET_ME_UUID__
CLIENT_UUID=__SET_ME_UUID__
EXPECTED_FIAT_AMOUNT=50
FIAT_CODE=USD
# EXPIRES_AT=
EXPIRES_IN_DAYS=30
INVOICE_NAME=load-test
INVOICE_NOTE=

# ---------- Withdrawals ----------
WD_RECIPIENT=__SET_ME_TRON_ADDRESS__
WD_AMOUNT=10
WD_AML=MEDIUM

# ---------- Мульти-юзер стресс (multiuser/: payout, withdrawal) ----------
PAYOUT_AML=HIGH
MU_VUS=
MU_DURATION=2m

# ---------- Debug ----------
DEBUG_AUTH_HEADERS=false

# ---------- Профиль нагрузки ----------
SMOKE_PER_H=1200
SMOKE_MIN=1
RAMP_START_PER_H=400
RAMP_END_PER_H=500
RAMP_MIN=15
HOLD_MIN=20
SPIKE_MULT=3
SPIKE_MIN=10
SOAK_PER_H=450
SOAK_MIN=30

# ---------- Мониторинг ----------
# K6_OUT=influxdb=http://localhost:8086/k6
