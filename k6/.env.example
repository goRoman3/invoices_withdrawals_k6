# k6/.env.example — шаблон окружения для нагрузочных сценариев.
# Скопируй в .env.local и подставь реальные значения:
#   cp .env.example .env.local
# .env.local в .gitignore и НЕ коммитится.

# ---------- Прогон ----------
VUS=1
ITERATIONS=1
ITERATION_DELAY=1

# ---------- Ретраи ----------
HTTP_RETRIES=2
INVOICE_RETRIES=1
LIST_RETRIES=1

# ---------- API ----------
BASE_URL=https://gateway.dev.gr8.sre.ideasoft.io

# ---------- Keycloak / OAuth ----------
KEYCLOAK_TOKEN_URL=https://keycloak.dev.gr8.sre.ideasoft.io/realms/gr8tech/protocol/openid-connect/token
CLIENT_ID=crm-api
CLIENT_SECRET=__SET_ME__
USERNAME=__SET_ME__
PASSWORD=__SET_ME__
SCOPE='openid email profile roles organization:*'
# Либо задай готовый токен и пропусти логин:
# ACCESS_TOKEN_MANUAL=

# ---------- OTP / TOTP ----------
OTP_SECRET=__SET_ME_BASE32__
OTP_FIELD=totp
NODE_TOTP_PATH=../tools/totp-node/totp.js
DEBUG_TOTP=false
OTP_BASE32_MODE=RFC
OTP_TIME_OFFSET_SECONDS=0
OTP_WINDOW=1
OTP_ALGO=SHA1
OTP_STEP=30
OTP_DIGITS=6
# OTP_MANUAL=

# ---------- Subproject ----------
SUBPROJECT_NAME=GR8Tech
SUBPROJECT_ID=__SET_ME_UUID__
SUBPROJECT_HEADER=x-subproject-id

# ---------- Invoice defaults ----------
ASSET_UUID=__SET_ME_UUID__
CLIENT_UUID=__SET_ME_UUID__
EXPECTED_FIAT_AMOUNT=50
FIAT_CODE=USD
# Оставь пустым, чтобы использовать относительный срок (now + EXPIRES_IN_DAYS).
# Либо задай явную ISO-дату.
# EXPIRES_AT=
EXPIRES_IN_DAYS=30
INVOICE_NAME=GR8Tech
INVOICE_NOTE=

# ---------- Debug ----------
DEBUG_AUTH_HEADERS=false

# ---------- Withdrawals: профиль нагрузки ----------
RAMP_START_PER_H=400
RAMP_END_PER_H=500
RAMP_MIN=15
HOLD_MIN=20
SPIKE_MULT=3
SPIKE_MIN=10
SOAK_PER_H=450
SOAK_MIN=30
